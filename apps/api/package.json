{
  "name": "smart-factory-api",
  "version": "1.0.0",
  "description": "Smart Factory Worker App - Backend API Server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "migrate": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate:mysql",
    "seed": "tsx src/seed.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.0.0",
    "@sentry/node": "^7.85.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-kit": "^0.20.0",
    "drizzle-orm": "^0.30.0",
    "exceljs": "^4.3.0",
    "express": "^5.0.0",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^118.0.0",
    "groq-sdk": "^0.5.0",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.6.0",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.13.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.2.3",
    "redis": "^5.0.0",
    "uuid": "^9.0.1",
    "ws": "^8.15.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.12.11",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.55.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
