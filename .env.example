# ==========================================
# 智慧工廠員工App - 環境變數範例
# ==========================================

# ========== APP 設定 ==========
NODE_ENV=development
PORT=3000

# ========== 資料庫 ==========
DATABASE_URL=postgresql://user:password@localhost:5432/smartfactory
DATABASE_URL_SHADOW=postgresql://user:password@localhost:5432/smartfactory_shadow

# ========== Redis (BullMQ) ==========
REDIS_URL=redis://localhost:6379

# ========== JWT 認證 ==========
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ========== Expo 推播 ==========
EXPO_ACCESS_TOKEN=your-expo-access-token
EXPO_PROJECT_ID=your-expo-project-id

# ========== LINE Bot ==========
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_RICH_MENU_ID=your-rich-menu-id

# ========== Groq AI (免費方案) ==========
GROQ_API_KEY=your-groq-api-key-from-console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile

# ========== 前端應用 ==========
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_WS_URL=ws://localhost:3000
EXPO_PUBLIC_APP_NAME=智慧工廠

# ========== Sentry 監控（選用）==========
SENTRY_DSN=

# ========== Google Sheets 同步（選用）==========
GAS_API_URL=
GOOGLE_SHEETS_ID=

# ========== 日誌 ==========
LOG_LEVEL=info
