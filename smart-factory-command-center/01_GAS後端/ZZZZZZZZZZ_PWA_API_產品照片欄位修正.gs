/**
 * 檔案名稱：ZZZZZZZZZZ_PWA_API_產品照片欄位修正.gs
 * 目的：修正 PWA 報工初始資料產品照片為 0 的問題。
 *
 * 原因：
 * ZZZZZZZ_主檔照片直掛讀取正式版.gs 寫入 02_產品主檔 的欄位名稱是：
 * - 產品主圖網址
 * - 產品主圖縮圖網址
 * - 前視圖網址 / 前視圖縮圖網址
 * - 側視圖網址 / 側視圖縮圖網址
 * - 俯視圖網址 / 俯視圖縮圖網址
 *
 * 但原 PWA 照片合併檔主要讀「產品主圖、產品照片網址、產品縮圖網址」，
 * 因此會造成 PWA 狀態列顯示：照片:產品0/機台7。
 *
 * 這支檔案只覆寫產品照片讀取與群組合併邏輯，不改報工寫入邏輯。
 */

function PWA產品照片修正_取值_(row, keys) {
  row = row || {};
  for (const k of keys) {
    if (row[k] !== undefined && row[k] !== null && String(row[k]).trim() !== '') return row[k];
  }
  return '';
}

function PWA產品照片修正_文字_(v) {
  return String(v == null ? '' : v).trim();
}

function PWA產品照片修正_圖片_(v) {
  let s = PWA產品照片修正_文字_(v);
  if (!s) return '';
  s = s.replace(/^=IMAGE\(/i, '').replace(/["'()]/g, '').trim();
  const url = s.match(/https?:\/\/[^\s,，;；]+/i);
  if (url) s = url[0];
  if (s.indexOf('data:image/') === 0) return s;
  const id = s.match(/[-\w]{25,}/);
  if (id) return 'https://drive.google.com/thumbnail?id=' + id[0] + '&sz=w900';
  return s;
}

/**
 * 覆寫：讀取 02_產品主檔。
 * 重點補上真正欄位：產品主圖網址 / 產品主圖縮圖網址 / 前側俯視圖。
 */
function PWA照片補強_讀產品主檔_() {
  return PWA照片補強_讀表_('02_產品主檔')
    .filter(r => PWA產品照片修正_文字_(r.啟用 || '是') !== '否')
    .map(r => {
      const 主圖來源 = PWA產品照片修正_取值_(r, [
        '產品主圖網址',
        '產品主圖縮圖網址',
        '產品主圖',
        '產品照片網址',
        '產品縮圖網址',
        '產品圖片網址',
        '主圖',
        '照片網址',
        '縮圖網址',
        '圖片網址',
        '產品主圖檔案ID',
        '產品照片檔案ID',
        'Google檔案ID',
        '照片檔案ID',
        '檔案ID'
      ]);

      const 前視圖 = PWA產品照片修正_圖片_(PWA產品照片修正_取值_(r, ['前視圖網址', '前視圖縮圖網址', '前視圖檔案ID']));
      const 側視圖 = PWA產品照片修正_圖片_(PWA產品照片修正_取值_(r, ['側視圖網址', '側視圖縮圖網址', '側視圖檔案ID']));
      const 俯視圖 = PWA產品照片修正_圖片_(PWA產品照片修正_取值_(r, ['俯視圖網址', '俯視圖縮圖網址', '俯視圖檔案ID']));
      const 三視圖來源 = PWA產品照片修正_取值_(r, [
        '產品三視圖', '三視圖', '三視圖網址', '產品三視圖網址', '三視圖檔案ID', '產品三視圖檔案ID'
      ]);

      const 主圖 = PWA產品照片修正_圖片_(主圖來源);
      const 三視圖 = PWA產品照片修正_圖片_(三視圖來源) || [前視圖, 側視圖, 俯視圖].filter(Boolean).join('、');

      return {
        產品編號: PWA產品照片修正_文字_(PWA產品照片修正_取值_(r, ['產品編號', '料號', '品號', '產品料號', 'productNo'])),
        客戶品號: PWA產品照片修正_文字_(PWA產品照片修正_取值_(r, ['客戶品號', '客戶料號'])),
        品名: PWA產品照片修正_文字_(PWA產品照片修正_取值_(r, ['品名', '產品名稱', 'name'])),
        分類: PWA產品照片修正_文字_(PWA產品照片修正_取值_(r, ['分類', '產品分類'])),
        標準工時_秒: PWA產品照片修正_取值_(r, ['標準工時_秒', '標準工時']),
        '8小時標準產能': PWA產品照片修正_取值_(r, ['8小時標準產能', '標準產能_班', '8H產能']),
        啟用: r.啟用 || '是',

        // PWA 統一讀這三個欄位
        產品主圖: 主圖,
        產品照片網址: 主圖,
        產品縮圖網址: 主圖,
        產品照片: 主圖,

        // 三視圖保留完整資料
        產品三視圖: 三視圖,
        前視圖網址: 前視圖,
        側視圖網址: 側視圖,
        俯視圖網址: 俯視圖,
        三視圖完整度: r.三視圖完整度 || '',

        產品照片檔案ID: PWA產品照片修正_文字_(PWA產品照片修正_取值_(r, ['產品主圖檔案ID', '產品照片檔案ID', 'Google檔案ID', '照片檔案ID', '檔案ID']))
      };
    })
    .filter(x => x.產品編號 || x.客戶品號 || x.品名);
}

/**
 * 覆寫：建立報工工站群組。
 * 重點：產品照片不只看工站列本身，也必須用 產品編號 / 客戶品號 / 品名 回補 02_產品主檔照片。
 */
function PWA照片補強_建立報工工站群組_(產品, 工站, 機台) {
  const source = 工站.length ? 工站 : 產品.map(p => Object.assign({}, p, { 工站名稱: '未指定工站', 報工工站名稱: '未指定工站' }));

  return source.map(row => {
    const rowKeys = [
      PWA產品照片修正_文字_(PWA產品照片修正_取值_(row, ['產品編號', '料號', '品號', '產品料號'])),
      PWA產品照片修正_文字_(PWA產品照片修正_取值_(row, ['客戶品號', '客戶料號'])),
      PWA產品照片修正_文字_(PWA產品照片修正_取值_(row, ['品名', '產品名稱']))
    ].filter(Boolean);

    const p = 產品.find(prod => [prod.產品編號, prod.客戶品號, prod.品名].some(k => k && rowKeys.indexOf(k) >= 0)) || {};

    const 產品編號 = rowKeys[0] || p.產品編號 || '';
    const 客戶品號 = rowKeys[1] || p.客戶品號 || '';
    const 品名 = rowKeys[2] || p.品名 || '';
    const 工站名稱 = PWA產品照片修正_文字_(PWA產品照片修正_取值_(row, ['報工工站名稱', '工站名稱', '名稱', '工站編號', '工站代碼'])) || '未指定工站';
    const 工序 = PWA產品照片修正_文字_(PWA產品照片修正_取值_(row, ['工序', '工序範圍', '工序清單', '工站代碼']));

    const rawMachine = PWA產品照片修正_文字_(PWA產品照片修正_取值_(row, ['機台清單', '機台編號清單', '機台編號', '主機台']));
    let ids = rawMachine ? rawMachine.split(/[、,，;；\s]+/).filter(Boolean) : [];
    if (!ids.length) {
      ids = 機台
        .filter(m => [m.工站編號, m.工站名稱].some(v => PWA產品照片修正_文字_(v) && [工站名稱, 工序].indexOf(PWA產品照片修正_文字_(v)) >= 0))
        .map(m => m.機台編號);
    }

    const 機台清單 = ids.map(id => {
      const m = 機台.find(x => x.機台編號 === id) || {};
      return {
        機台編號: id,
        設備名稱: m.機台名稱 || id,
        區域: m.區域 || '',
        機台型號: m.型號 || '',
        照片網址: m.照片網址 || m.機台照片 || '',
        縮圖網址: m.縮圖網址 || m.照片網址 || m.機台照片 || ''
      };
    });

    const rowPhoto = PWA產品照片修正_圖片_(PWA產品照片修正_取值_(row, [
      '產品主圖網址', '產品主圖縮圖網址', '產品主圖', '產品照片網址', '產品縮圖網址', '照片網址', '圖片網址'
    ]));
    const productPhoto = rowPhoto || p.產品照片網址 || p.產品主圖 || p.產品縮圖網址 || p.產品照片 || '';

    const productThree = PWA產品照片修正_圖片_(PWA產品照片修正_取值_(row, [
      '產品三視圖', '三視圖', '三視圖網址', '前視圖網址', '側視圖網址', '俯視圖網址'
    ])) || p.產品三視圖 || '';

    return Object.assign({}, row, {
      產品編號,
      客戶品號,
      品名,
      產品主圖: productPhoto,
      產品照片網址: productPhoto,
      產品縮圖網址: productPhoto,
      產品照片: productPhoto,
      產品三視圖: productThree,
      前視圖網址: p.前視圖網址 || '',
      側視圖網址: p.側視圖網址 || '',
      俯視圖網址: p.俯視圖網址 || '',
      產品照片檔案ID: p.產品照片檔案ID || '',
      工站名稱,
      報工工站名稱: 工站名稱,
      工序,
      工序範圍: PWA產品照片修正_文字_(PWA產品照片修正_取值_(row, ['工序範圍'])) || 工序,
      工序清單: 工序 ? 工序.split(/[、,，;；\s]+/).filter(Boolean) : [],
      機台清單,
      主機台: PWA產品照片修正_文字_(PWA產品照片修正_取值_(row, ['主機台'])) || (機台清單[0] ? 機台清單[0].機台編號 : ''),
      標準產能: PWA產品照片修正_取值_(row, ['標準產能', '標準產能_班', '8小時標準產能']) || p['8小時標準產能'] || '',
      標準工時_秒: PWA產品照片修正_取值_(row, ['標準工時_秒', '標準工時']) || p.標準工時_秒 || ''
    });
  }).filter(x => x.產品編號 || x.客戶品號 || x.品名 || x.報工工站名稱);
}
