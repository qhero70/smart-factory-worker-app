/**
 * 檔案名稱：ZZZZZZZZZZZZ_PWA_API_人員班別早中夜修正正式版.gs
 * 專案：智慧製造中央作戰指揮中心
 * 目的：修正 PWA 報工人員卡片把「化新早班(0800~1650)」誤判成「中班」的問題。
 *
 * 問題原因：
 * 原 PWA_API_讀人員主檔_() 只回傳「班別」一個欄位，且標準化時容易因 1650 誤判中班。
 * 實際 01_人員主檔已有：
 * - 班別：化新早班(0800~1650)
 * - 班別代碼：DAY
 * - 班別名稱：早班
 * - 班別開始時間：8:00
 * - 班別結束時間：16:50
 *
 * 修正原則：
 * 1. 優先讀「班別名稱」。
 * 2. 再讀「班別代碼」。
 * 3. 再讀開始/結束時間。
 * 4. 0800~1650 永遠是早班，不可因 1650 被判成中班。
 * 5. 保留原始班別欄位給前端除錯。
 */

function PWA班別修正_文字_(v) {
  return String(v == null ? '' : v).trim();
}

function PWA班別修正_清字_(v) {
  return PWA班別修正_文字_(v).replace(/\s+/g, '').toUpperCase();
}

function PWA班別修正_取值_(row, keys) {
  row = row || {};
  for (const k of keys) {
    if (row[k] !== undefined && row[k] !== null && PWA班別修正_文字_(row[k]) !== '') return row[k];
  }
  return '';
}

function PWA班別修正_標準班別_(row) {
  row = row || {};

  const 班別名稱 = PWA班別修正_文字_(PWA班別修正_取值_(row, ['班別名稱', '標準班別', '顯示班別']));
  const 班別代碼 = PWA班別修正_清字_(PWA班別修正_取值_(row, ['班別代碼', '班別CODE', 'shiftCode', 'ShiftCode']));
  const 原始班別 = PWA班別修正_文字_(PWA班別修正_取值_(row, ['班別', '班次', '工作班別', '原始班別', '班別時間']));
  const 開始時間 = PWA班別修正_清字_(PWA班別修正_取值_(row, ['班別開始時間', '開始時間', '上班時間']));
  const 結束時間 = PWA班別修正_清字_(PWA班別修正_取值_(row, ['班別結束時間', '結束時間', '下班時間']));
  const all = PWA班別修正_清字_([班別名稱, 班別代碼, 原始班別, 開始時間, 結束時間].join(' '));

  // 最高優先：明確欄位
  if (班別名稱.indexOf('早') >= 0) return '早班';
  if (班別名稱.indexOf('中') >= 0) return '中班';
  if (班別名稱.indexOf('大夜') >= 0 || 班別名稱.indexOf('夜') >= 0) return '大夜班';

  // 第二優先：班別代碼
  if (班別代碼 === 'DAY' || 班別代碼 === 'D') return '早班';
  if (班別代碼 === 'NIGHT' || 班別代碼 === 'N') return '大夜班';
  if (班別代碼 === 'MID' || 班別代碼 === 'M' || 班別代碼 === 'SWING') return '中班';

  // 第三優先：時間區間。0800~1650 是早班，不是中班。
  if (all.indexOf('0800') >= 0 || all.indexOf('08:00') >= 0 || all.indexOf('8:00') >= 0) return '早班';
  if (all.indexOf('2300') >= 0 || all.indexOf('23:00') >= 0 || all.indexOf('3150') >= 0 || all.indexOf('0315') >= 0 || all.indexOf('03:15') >= 0 || all.indexOf('7:50') >= 0 || all.indexOf('0750') >= 0) return '大夜班';

  // 第四優先：原始文字。注意早班要先判斷。
  if (原始班別.indexOf('早') >= 0) return '早班';
  if (原始班別.indexOf('大夜') >= 0 || 原始班別.indexOf('夜') >= 0) return '大夜班';
  if (原始班別.indexOf('中') >= 0) return '中班';

  // 只有「沒有 0800」而含 1650，才可視為中班開始。
  if (all.indexOf('1650') >= 0 && all.indexOf('0800') < 0) return '中班';

  return 原始班別 || 班別名稱 || '';
}

function PWA班別修正_取主檔照片_(row) {
  // 優先使用既有 PWA_API_取主檔照片_，避免重複邏輯。
  if (typeof PWA_API_取主檔照片_ === 'function') {
    return PWA_API_取主檔照片_(
      row,
      ['人員照片網址', '人員縮圖網址', '人員照片縮圖網址', '人員照片', '照片網址', '縮圖網址', '作業員照片網址', '作業員縮圖網址', '圖片網址', '頭像網址'],
      ['人員照片檔案ID', 'Google檔案ID', '作業員照片檔案ID', '照片檔案ID', '檔案ID']
    );
  }
  return { 照片網址: '', 縮圖網址: '', 檔案ID: '' };
}

/**
 * 覆寫原本 PWA_API_讀人員主檔_。
 * 這支檔案名稱 ZZZZZZZZZZZZ 開頭，讓它在後面載入，覆蓋舊版函式。
 */
function PWA_API_讀人員主檔_() {
  return 讀表_('01_人員主檔')
    .filter(r => 文字_(r.啟用 || '是') !== '否')
    .map(r => {
      const 工號 = 取值_(r, ['工號', '員工編號', '員工工號', 'id']);
      const 照片 = PWA班別修正_取主檔照片_(r);
      const 標準班別 = PWA班別修正_標準班別_(r);

      return {
        工號,
        姓名: 取值_(r, ['姓名', '中文名', '名字', 'name']),
        部門: 取值_(r, ['部門', '單位', 'dept']),
        組別: 取值_(r, ['組別', '班組', 'group']),
        職稱: 取值_(r, ['職稱', '職位', 'title']),

        // PWA 主欄位：一定回正確早班 / 中班 / 大夜班
        班別: 標準班別,
        班別名稱: 標準班別,

        // 保留原始欄位，讓前端與除錯可以看見真實來源
        原始班別: PWA班別修正_取值_(r, ['班別', '班次', '工作班別', '原始班別']),
        班別代碼: PWA班別修正_取值_(r, ['班別代碼', '班別CODE', 'shiftCode', 'ShiftCode']),
        班別開始時間: PWA班別修正_取值_(r, ['班別開始時間', '開始時間', '上班時間']),
        班別結束時間: PWA班別修正_取值_(r, ['班別結束時間', '結束時間', '下班時間']),
        班別判斷來源: 'ZZZZZZZZZZZZ_PWA_API_人員班別早中夜修正正式版.gs',

        啟用: r.啟用 || '是',
        人員照片: 照片.照片網址,
        人員照片網址: 照片.照片網址,
        照片網址: 照片.照片網址,
        縮圖網址: 照片.縮圖網址,
        Google檔案ID: 照片.檔案ID
      };
    });
}
