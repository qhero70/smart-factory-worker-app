/*******************************************************
 * 05_GAS_API_04工站資料對接
 * 專案：智慧製造中央作戰指揮中心
 * 階段：第三階段 Google Apps Script 後端 API 對接
 *
 * 功能：
 * 1. 讓既有 action=取得主檔資料 同步回傳三張 04 工站關聯表。
 * 2. 提供獨立測試函數，確認 PWA 後續可讀取工站 / 機台 / 產品 / 班別產能資料。
 * 3. 不宣告 doGet / doPost，不破壞正式主入口。
 *******************************************************/

function 取得主檔資料_() {
  if (typeof 補齊04工站關聯規格_ === 'function') {
    補齊04工站關聯規格_();
  }

  return {
    成功: true,
    來源: '05_GAS_API_04工站資料對接',
    更新時間: new Date(),
    人員: 表格轉物件_('01_人員主檔'),
    產品: 表格轉物件_('02_產品主檔'),
    機台: 表格轉物件_('03_機台主檔'),
    工站: 表格轉物件_('04_工站主檔'),
    工站產品關聯: 表格轉物件_('04_工站產品關聯'),
    工站機台關聯: 表格轉物件_('04_工站機台關聯'),
    工站班別產能: 表格轉物件_('04_工站班別產能'),
    工單: 表格轉物件_('10_工單主檔'),
    排程需求: 表格轉物件_('10_排程需求池'),
    檢具: 表格轉物件_('11_檢具主檔'),
    共用: 表格轉物件_('05_共用資料')
  };
}

function 取得04工站API資料() {
  if (typeof 補齊04工站關聯規格_ === 'function') {
    補齊04工站關聯規格_();
  }

  const 工站產品關聯 = 表格轉物件_('04_工站產品關聯');
  const 工站機台關聯 = 表格轉物件_('04_工站機台關聯');
  const 工站班別產能 = 表格轉物件_('04_工站班別產能');

  return {
    成功: true,
    訊息: '04 工站 API 資料讀取完成',
    更新時間: new Date(),
    筆數: {
      工站產品關聯: 工站產品關聯.length,
      工站機台關聯: 工站機台關聯.length,
      工站班別產能: 工站班別產能.length
    },
    資料: {
      工站產品關聯: 工站產品關聯,
      工站機台關聯: 工站機台關聯,
      工站班別產能: 工站班別產能
    }
  };
}

function 測試04工站API資料() {
  const 結果 = 取得04工站API資料();
  const 檢查 = {
    成功: 結果.成功 === true &&
      結果.筆數.工站產品關聯 === 259 &&
      結果.筆數.工站機台關聯 === 282 &&
      結果.筆數.工站班別產能 === 259,
    預期筆數: {
      工站產品關聯: 259,
      工站機台關聯: 282,
      工站班別產能: 259
    },
    實際筆數: 結果.筆數,
    測試時間: new Date()
  };

  Logger.log(JSON.stringify(檢查, null, 2));
  return 檢查;
}

function 測試取得主檔資料API() {
  const 結果 = 取得主檔資料_();
  const 檢查 = {
    成功: 結果.成功 === true &&
      Array.isArray(結果.工站產品關聯) &&
      Array.isArray(結果.工站機台關聯) &&
      Array.isArray(結果.工站班別產能),
    筆數: {
      人員: 結果.人員.length,
      產品: 結果.產品.length,
      機台: 結果.機台.length,
      工站: 結果.工站.length,
      工站產品關聯: 結果.工站產品關聯.length,
      工站機台關聯: 結果.工站機台關聯.length,
      工站班別產能: 結果.工站班別產能.length
    },
    測試時間: new Date()
  };

  Logger.log(JSON.stringify(檢查, null, 2));
  return 檢查;
}
